{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Room",
  "type": "object",
  "required": [
    "id", "name", "room_type", "station_count", "station_type", "capacity"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^room_[a-z0-9_]+$"
    },
    "name": { "type": "string" },
    "room_type": {
      "type": "string",
      "enum": ["pc_lab", "large_game_lab", "mac_lab", "flex_studio", "lecture_flex"]
    },
    "station_count": { "type": "integer", "minimum": 0 },
    "station_type": {
      "type": ["string", "null"],
      "enum": ["pc", "mac", null]
    },
    "capacity": { "type": "integer", "minimum": 1 },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
