{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Room",
  "type": "object",
  "required": [
    "id", "name", "station_count", "capacity"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^room_[a-z0-9_]+$"
    },
    "name": { "type": "string" },
    "campus": {
      "type": "string",
      "enum": ["Savannah", "Atlanta", "Lacoste"]
    },
    "building": { "type": "string" },
    "room_number": { "type": "string" },
    "station_count": { "type": "integer", "minimum": 0 },
    "display_count": { "type": "integer", "minimum": 0 },
    "capacity": { "type": "integer", "minimum": 1 },
    "available": { "type": "boolean" },
    "equipment_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
